#!/usr/bin/env bash

set -euo pipefail

for src in src/pub/*; do

  if [[ -f "$src" ]]; then

    printf "Building $src\n"

    dst="${src/src/dst}"

    mkdir -p dst/pub/

    cp "$src" "$dst"

  fi

done

for src in src/pub.lib.*/; do
  
  if [[ -d "$src" ]]; then

    printf "Building $src\n"

    dst="${src/src/dst}"
    dst="${dst//./\/}"

    mkdir -p "$dst"

    cp -r -T "$src" "$dst"

  fi

done

for src in src/pub.*/; do

  if [[ -d "$src" && ! "$src" =~ ^src/pub.lib.*/$ ]]; then

	printf "Building $src\n"

	tmp="${src%\/}"

	src="$src${tmp##*.}"

	dst="${tmp/src/dst}"
	dst="${dst//./\/}"

	mkdir -p "${dst%/*}"/

	if [[ -f "$src".html ]]; then

	  if [[ "${MODE:-development}" == production ]]; then

		npx ejs "$src".html -o "$dst".html -m ! -w

	  else

		npx ejs "$src".html -o "$dst".html -m !

	  fi

	fi

	if [[ -f "$src".css ]]; then

	  if [[ "${MODE:-development}" == production ]]; then

		npx lightningcss "$src".css -o "$dst".css --bundle --browserslist --minify

	  else

		npx lightningcss "$src".css -o "$dst".css --bundle --browserslist

	  fi

	fi

	if [[ -f "$src".js ]]; then

	  npx rolldown "$src".js -o "$dst".combined.js -f iife

	  npx swc "$dst".combined.js -o "$dst".transpiled.js

	  if [[ "${MODE:-development}" == production ]]; then

		npx rolldown "$dst".transpiled.js -o "$dst".js -m

	  else

		cp "$dst".transpiled.js "$dst".js

	  fi

	  rm "$dst".combined.js
	  rm "$dst".transpiled.js

	fi

	if [[ -f "${src%/*}"/Handler.java ]]; then

	  if [[ "${MODE:-development}" == production ]]; then

		javac -cp "dst/lib/*" "${src%/*}"/Handler.java -d "${dst%/*}"/

	  else

		javac -cp "dst/lib/*" "${src%/*}"/Handler.java -d "${dst%/*}"/ -g

	  fi

	  args=(-C "${dst%/*}"/ Handler.class)

	  if [[ -d "${src%/*}"/resources/ ]]; then

		args+=(-C "${src%/*}"/ resources/)

	  fi

	  if [[ -f "$dst".html ]]; then

		args+=(-C "${dst%/*}"/ "${dst##*/}".html)

	  fi

	  jar cf "$dst".jar "${args[@]}"

	  rm "${dst%/*}"/Handler.class

	  rm -f "$dst".html

	fi

  fi

done

printf "Done\n"

